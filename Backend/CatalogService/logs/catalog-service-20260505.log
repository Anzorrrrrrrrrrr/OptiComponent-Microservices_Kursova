SELECT [o].[Id], [o].[OrderNumber], [o].[CustomerName], [o].[OrderDate], [o].[TotalPrice], CASE [o].[Status]
    WHEN 0 THEN N'New'
    WHEN 1 THEN N'Processing'
    WHEN 2 THEN N'Shipped'
    WHEN 3 THEN N'Completed'
    WHEN 4 THEN N'Cancelled'
    ELSE CAST([o].[Status] AS nvarchar(max))
END, (
    SELECT COUNT(*)
    FROM [OrderItems] AS [o0]
    WHERE [o].[Id] = [o0].[OrderId]), [s].[ComponentName], [s].[Quantity], [s].[UnitPrice], [s].[Id], [s].[Id0]
FROM [Orders] AS [o]
LEFT JOIN (
    SELECT [c].[Name] AS [ComponentName], [o1].[Quantity], [o1].[UnitPrice], [o1].[Id], [c].[Id] AS [Id0], [o1].[OrderId]
    FROM [OrderItems] AS [o1]
    INNER JOIN [Components] AS [c] ON [o1].[ComponentId] = [c].[Id]
) AS [s] ON [o].[Id] = [s].[OrderId]
ORDER BY [o].[OrderDate] DESC, [o].[Id], [s].[Id]
